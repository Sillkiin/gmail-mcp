{
  "name": "gmail-mcp",
  "version": "0.1.0",
  "description": "An MCP server that turns your Gmail into structured data — search, read, and batch-read tools optimized for letting Claude/Cursor extract contacts, orders, and tables from your inbox.",
  "type": "module",
  "bin": {
    "gmail-mcp": "dist/src/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "authorize": "node dist/scripts/authorize.js",
    "test": "tsc && node --test \"dist/test/*.test.js\"",
    "prepare": "tsc"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "gmail",
    "claude",
    "cursor",
    "email",
    "data-extraction",
    "ai"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "googleapis": "^144.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
